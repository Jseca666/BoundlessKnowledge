	"gates": [
		{
			"id": "no-agent-doc-bloat",
			"rule": "Do not add module-specific instructions, workflow details, output templates or schema fields to AGENTS.md, SKILL.md, module baseline docs, child-agent docs or subsystem README entrypoints. Add or update route, docs map, registry, schema or workflow surfaces instead."
		},
		{
			"id": "machine-first-routing",
			"rule": "Prefer JSON route and information maps for system behavior; Markdown is explanatory."
		},
		{
			"id": "coordinated-upgrade-check",
			"rule": "Before finishing a system change, check affected modules, schemas, dataflows, gates, routes, workflows, tools, memory and indexes."
		},
		{
			"id": "no-unregistered-stable-module",
			"rule": "A stable module, tool, workflow, schema, index, loop or canvas must have a declared storage home, canonical truth, route or registry entry, validation path and lifecycle status."
		},
		{
			"id": "no-visual-blind-spot",
			"rule": "Every stable module or important system structure must have an explicit visual coverage decision in system/visual-coverage-map.json: required dedicated view, shared required view, deferred with review trigger, or not_applicable with reason."
		},
		{
			"id": "no-unlayered-stable-module",
			"rule": "Every stable module in information-map and system-closure-map must have exactly one owner_layer assignment in system/module-layer-model.json; Canvas view_level and filesystem path cannot substitute for module ownership."
		},
		{
			"id": "system-structure-governance-before-new-branch",
			"rule": "New stable module placement should first produce a system-structure-governance decision: attach to existing module, create child module, create peer module, create new branch, defer as draft, or merge/retire."
		},
		{
			"id": "new-system-module-inherits-legacy-assets",
			"rule": "A new or upgraded system module must audit existing content in its responsibility boundary and explicitly adopt, migrate, deprecate, archive, exempt, or queue follow-up before the upgrade is accepted."
		},
		{
			"id": "module-activation-proof-before-effective",
			"rule": "Do not claim a new or upgraded stable system module is active/effective until system/system-closure-map.json contains activation_proof required by system/module-governance-policy.json module_activation_contract."
		},
		{
			"id": "diagnostic-self-audit-after-user-correction",
			"rule": "When the user points out that a diagnosis missed the higher-layer cause, wrong ownership, incomplete surfaces or false closure, treat diagnostics itself as an affected module and record diagnostic_self_audit before claiming closure."
		},
		{
			"id": "same-class-impact-scan-before-closure",
			"rule": "When a repair is system_upgrade or the user says the issue is broader than the named object, record generalization_scan across same-class assets and sibling surfaces before claiming closure."
		},
		{
			"id": "no-incident-as-root-problem",
			"rule": "A system_upgrade diagnosis must not treat the observed accident or visible symptom as the root problem. It must separate incident_manifestation, root_problem and system_regulation_target before repair closure."
		},
		{
			"id": "thin-entrypoints-route-to-machine-truth",
			"rule": "Every stable entrypoint document must route to machine truth and stay thin; internal module entrypoints follow the same rule as root AGENTS.md."
		},
		{
			"id": "knowledge-engineering-root-identity",
			"rule": "When discussing project purpose, system/business relationship or Codex workflow role, route through system/project-ontology.json and treat 无界知识 as a knowledge engineering system. Domain taxonomy and project consumption are internal surfaces, not the root identity."
		}
	]
}
