{
	"id": "system-closure-map",
	"version": "0.9.0",
	"updated": "2026-06-10",
	"role": "machine-readable-module-closure-matrix",
	"purpose": "Track whether each stable module has enough routing, truth, validation, documentation, diagnostics and lifecycle coverage to be maintained without relying on chat memory.",
	"principle": "Closure means a module can be found, understood, modified, validated and repaired through registered system surfaces.",
	"status_values": [
		{
			"status": "closed",
			"meaning": "The facet has a durable registered owner and validation or route coverage."
		},
		{
			"status": "shared",
			"meaning": "The facet is covered by a broader route, validator or subsystem rather than a dedicated one."
		},
		{
			"status": "partial",
			"meaning": "The facet exists but has known gaps or weak automation."
		},
		{
			"status": "seed",
			"meaning": "The facet is newly created and intentionally thin."
		},
		{
			"status": "missing",
			"meaning": "The facet should exist but has no durable registered asset."
		},
		{
			"status": "not_applicable",
			"meaning": "The facet is not required for this module at the current lifecycle stage."
		}
	],
	"required_facets": [
		{
			"id": "information_map",
			"question": "Is the module registered in system/information-map.json with a boundary and paths?"
		},
		{
			"id": "canonical_truth",
			"question": "Does the module declare the machine-readable files or directories that act as truth?"
		},
		{
			"id": "route",
			"question": "Can future tasks route to the right read, update and validation surfaces?"
		},
		{
			"id": "validation",
			"question": "Can drift or missing files be detected by a registered validator?"
		},
		{
			"id": "documentation",
			"question": "Is human explanation thin, routed and separated from machine truth?"
		},
		{
			"id": "visual_projection",
			"question": "Does the module need a Canvas view, and if yes is it registered?"
		},
		{
			"id": "diagnostics",
			"question": "Can failures enter the diagnostic repair loop?"
		},
		{
			"id": "lifecycle",
			"question": "Is the module current, partial, seed, archived or otherwise explicitly staged?"
		}
	],
	"closure_rule": {
		"new_module_gate": "Every module in system/information-map.json must appear in this map.",
		"route_gate": "Every route_id listed here must exist in system/route-registry.json.",
		"path_gate": "Every canonical_truth, validation, documentation and visual view path listed here must exist.",
		"gap_rule": "A partial or seed module must state known_gaps and next_action.",
		"visual_coverage_gate": "Every closure module must have a matching module_decision in system/visual-coverage-map.json; closed/shared visual_projection views must be covered by required_views and registered in canvas-registry.",
		"layer_gate": "Every closure module owner_layer must match system/module-layer-model.json, and every information-map module must have one model assignment."
	},
