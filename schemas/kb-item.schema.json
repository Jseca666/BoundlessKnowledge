{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/wujie-knowledge/kb-item.schema.json",
  "title": "Knowledge Base Markdown Frontmatter",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "status",
    "created",
    "updated",
    "tags",
    "sources",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "source-paper",
        "source-github",
        "source-web",
        "source-personal",
        "atomic-note",
        "concept",
        "claim",
        "method",
        "domain-map",
        "synthesis",
        "workflow",
        "eval",
        "source-book"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "inbox",
        "draft",
        "active",
        "review",
        "seed",
        "superseded",
        "archived"
      ]
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflows": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
